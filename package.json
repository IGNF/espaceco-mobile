{
  "name": "guichet-mobile",
  "version": "3.0.6",
  "description": "Espace collaboratif mobile",
  "directories": {},
  "scripts": {
    "clean-dist": "rm -rf www && mkdir www",
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node ./scripts/setproject.js && vite",
    "backup": "node ./scripts/backup.js",
    "lint": "eslint --fix src/ || exit 0",
    "build-dev": "npm run clean-dist && node ./scripts/setproject.js && vite build --mode development",
    "build": "npm run clean-dist && node ./scripts/setproject.js && vite build",
    "capacitor-build-dev": "npm run build-dev && npx cap sync",
    "capacitor-build": "npm run build && npx cap sync",
    "capacitor-run-ios": "npm run capacitor-build && npx cap run ios",
    "capacitor-run-ios-dev": "npm run capacitor-build-dev && npx cap run ios",
    "capacitor-run-android": "npm run capacitor-build && npx cap run android",
    "capacitor-run-android-dev": "npm run capacitor-build-dev && npx cap run android",
    "open-xcode": "npx cap open ios",
    "open-android": "npx cap open android"
  },
  "repository": {},
  "keywords": [],
  "author": "sai-mobile@ign.fr",
  "license": "IGN",
  "bugs": {
    "url": "http://sd-redmine.ign.fr/projects/guichet_mobile"
  },
  "homepage": "https://github.com/IGNF/espaceco-mobile",
  "dependencies": {
    "@capacitor-community/keep-awake": "^7.1.0",
    "@capacitor/android": "^7.4.3",
    "@capacitor/app": "7.0.2",
    "@capacitor/app-launcher": "7.0.2",
    "@capacitor/camera": "^7.0.2",
    "@capacitor/core": "7.4.3",
    "@capacitor/filesystem": "^7.1.4",
    "@capacitor/ios": "^7.4.3",
    "@capacitor/keyboard": "^7.0.2",
    "@capacitor/network": "^7.0.2",
    "@capacitor/status-bar": "^7.0.2",
    "@capawesome/capacitor-android-edge-to-edge-support": "^7.2.3",
    "ajv": "6.12.*",
    "capacitor-email-composer": "^7.0.2",
    "cordova-plugin-bluetooth-serial": "github:giuseppelanzi/BluetoothSerial",
    "cordova-plugin-dialogs": "^2.0.2",
    "cordova-plugin-geolocation": "^4.0.2",
    "cordova-plugin-listpicker": "^2.2.2",
    "cordovapp": "https://github.com/IGNF/mobile-core.git",
    "dotenv": "^16.0.3",
    "jquery": "^3.4.1",
    "lightningcss": "^1.22.1",
    "mongo-parse": "^2.1.0",
    "ol": "^5.3.3",
    "ol-ext": "v4.0.17",
    "papaparse": "^5.3.0",
    "proj4": "^2.5.0",
    "webfontloader": "^1.6.28"
  },
  "devDependencies": {
    "@capacitor/cli": "7.4.3",
    "buffer": "^6.0.3",
    "clean-css": "^3.4.19",
    "cordova-plugin-background-mode": "github:brunochikuji/cordova-plugin-background-mode",
    "cordova-plugin-bluetooth-geolocation": "github:viglino/cordova-plugin-bluetooth-geolocation",
    "cordova-plugin-device": "^2.1.0",
    "cordova-plugin-file": "^8.1.3",
    "eslint": "^6.5.1",
    "events": "^3.3.0",
    "gulp-jsdoc3": "^3.0.0",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "sass": "^1.92.1",
    "stream-browserify": "^3.0.0",
    "uglify-js": "^2.6.4",
    "vite": "^7.1.5",
    "vm-browserify": "^1.1.2"
  },
  "staticFiles": {
    "staticPath": "src/assets",
    "watcherGlob": "**"
  },
  "targets": {
    "default": {
      "sourceMap": {
        "inline": true,
        "inlineSources": true
      }
    }
  }
}
