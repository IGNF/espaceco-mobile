{
  "name": "guichet-mobile",
  "version": "3.0.5",
  "description": "Espace collaboratif mobile",
  "directories": {},
  "scripts": {
    "clean-dist": "rm -rf www && mkdir www",
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node ./scripts/setproject.js && parcel ./src/index.html --dist-dir ./www",
    "backup": "node ./scripts/backup.js",
    "lint": "eslint --fix src/ || exit 0",
    "build-dev": "npm run clean-dist && node ./scripts/setproject.js && npx parcel build ./src/index.html --no-optimize --no-content-hash --public-url . --dist-dir ./www",
    "build": "npm run clean-dist && node ./scripts/setproject.js && npx parcel build ./src/index.html --no-source-maps --no-content-hash --public-url . --dist-dir ./www"
  },
  "repository": {},
  "keywords": [],
  "author": "sai-mobile@ign.fr",
  "license": "IGN",
  "bugs": {
    "url": "http://sd-redmine.ign.fr/projects/guichet_mobile"
  },
  "homepage": "https://github.com/IGNF/espaceco-mobile",
  "dependencies": {
    "ajv": "6.12.*",
    "cordova": "^12.0.0",
    "cordova-plugin-bluetooth-serial": "github:giuseppelanzi/BluetoothSerial",
    "cordova-plugin-dialogs": "^2.0.2",
    "cordova-plugin-file": "^6.0.1",
    "cordova-plugin-geolocation": "^4.0.2",
    "cordova-plugin-listpicker": "^2.2.2",
    "cordova-plugin-network-information": "^2.0.2",
    "cordovapp": "https://github.com/IGNF/cordovapp.git",
    "dotenv": "^16.0.3",
    "jquery": "^3.4.1",
    "lightningcss": "^1.22.1",
    "mongo-parse": "^2.1.0",
    "ol": "^5.3.3",
    "ol-ext": "v4.0.17",
    "papaparse": "^5.3.0",
    "proj4": "^2.5.0",
    "webfontloader": "^1.6.28"
  },
  "devDependencies": {
    "@parcel/transformer-sass": "^2.10.3",
    "buffer": "^6.0.3",
    "clean-css": "^3.4.19",
    "cordova-android": "^13.0.0",
    "cordova-ios": "^7.1.1",
    "cordova-plugin-background-mode": "github:brunochikuji/cordova-plugin-background-mode",
    "cordova-plugin-bluetooth-geolocation": "github:viglino/cordova-plugin-bluetooth-geolocation",
    "cordova-plugin-camera": "^8.0.0",
    "cordova-plugin-device": "^2.1.0",
    "cordova-plugin-email-composer": "^0.10.1",
    "cordova-plugin-inappbrowser": "^6.0.0",
    "cordova-plugin-insomnia": "github:EddyVerbruggen/Insomnia-PhoneGap-Plugin",
    "crypto-browserify": "^3.12.0",
    "eslint": "^6.5.1",
    "events": "^3.3.0",
    "gulp-jsdoc3": "^3.0.0",
    "os-browserify": "^0.3.0",
    "parcel": "2.10.*",
    "parcel-reporter-static-files-copy": "^1.5.0",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "string_decoder": "^1.3.0",
    "uglify-js": "^2.6.4",
    "vm-browserify": "^1.1.2"
  },
  "staticFiles": {
    "staticPath": "src/assets",
    "watcherGlob": "**"
  },
  "cordova": {
    "platforms": [
      "android"
    ],
    "plugins": {
      "cordova-plugin-file": {},
      "cordova-plugin-dialogs": {},
      "cordova-plugin-geolocation": {
        "GEOLOCATION_USAGE_DESCRIPTION": "pour localiser vos signalements",
        "GPS_REQUIRED": "true"
      },
      "cordova-plugin-network-information": {},
      "cordova-plugin-bluetooth-geolocation": {},
      "cordova-plugin-insomnia": {},
      "cordova-plugin-camera": {
        "CAMERA_USAGE_DESCRIPTION": "pour illustrez vos contributions",
        "PHOTOLIBRARY_USAGE_DESCRIPTION": "pour illustrez vos contributions",
        "ANDROIDX_CORE_VERSION": "1.6.+"
      },
      "cordova-plugin-inappbrowser": {},
      "cordova-plugin-background-mode": {},
      "cordova-plugin-email-composer": {}
    }
  },
  "targets": {
    "default": {
      "sourceMap": {
        "inline": true,
        "inlineSources": true
      }
    }
  }
}
