{
  "name": "guichet-mobile",
  "version": "1.1.8",
  "description": "Espace collaboratif mobile",
  "main": "index.html",
  "directories": {},
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "parcel ./src/index.html --out-dir ./.dist",
    "lint": "eslint --fix src/ || exit 0",
    "build-dev": "parcel build ./src/index.html --no-minify --no-source-maps --no-content-hash --public-url . --out-dir ./www index.html",
    "build": "parcel build ./src/index.html --no-source-maps --no-content-hash --public-url . --out-dir ./www index.html"
  },
  "repository": {},
  "keywords": [],
  "author": "sai-mobile@ign.fr",
  "license": "IGN",
  "bugs": {
    "url": "http://sd-redmine.ign.fr/projects/guichet_mobile"
  },
  "homepage": "http://gitlab.dockerforge.ign.fr/express/guichet-mobile",
  "dependencies": {
    "cordova-android": "^7.0.0",
    "cordova-plugin-camera": "^2.4.1",
    "cordova-plugin-compat": "^1.2.0",
    "cordova-plugin-dialogs": "^2.0.1",
    "cordova-plugin-file": "^6.0.1",
    "cordova-plugin-file-transfer": "^1.7.1",
    "cordova-plugin-geolocation": "^4.0.1",
    "cordova-plugin-inappbrowser": "^3.0.0",
    "cordova-plugin-network-information": "^2.0.1",
    "cordova-plugin-whitelist": "^1.3.3",
    "cordovapp": "git+http://gitlab.dockerforge.ign.fr/express/cordovapp.git",
    "crypto-js": "^3.1.9-1",
    "jquery": "^3.4.1",
    "ol": "^5.3.3",
    "ol-ext": "^3.1.4",
    "proj4": "^2.5.0",
    "webfontloader": "^1.6.28"
  },
  "devDependencies": {
    "clean-css": "^3.4.19",
    "cordova": "^8.1.2",
    "gulp": "^3.9.1",
    "gulp-jsdoc3": "^1.0.1",
    "npm": "^5.6.0",
    "parcel": "^1.12.3",
    "parcel-plugin-clean-dist": "0.0.6",
    "parcel-plugin-static-files-copy": "^2.2.0",
    "uglify-js": "^2.6.4"
  },
  "staticFiles": {
    "staticPath": [
      "src/assets"
    ],
    "watcherGlob": "**"
  },
  "cordova": {
    "platforms": [
      "android"
    ],
    "plugins": {
      "cordova-plugin-camera": {
        "CAMERA_USAGE_DESCRIPTION": "pour illustrer vos contributions",
        "PHOTOLIBRARY_USAGE_DESCRIPTION": "pour illustrer vos contributions"
      },
      "cordova-plugin-whitelist": {},
      "cordova-plugin-file-transfer": {},
      "cordova-plugin-dialogs": {},
      "cordova-plugin-geolocation": {
        "GEOLOCATION_USAGE_DESCRIPTION": "pour localiser vos signalements"
      },
      "cordova-plugin-inappbrowser": {},
      "cordova-plugin-network-information": {}
    }
  }
}
