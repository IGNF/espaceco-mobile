  "staticFiles": {
    "staticPath": [
      "src/assets"
    ],
    "watcherGlob": "**"
  },
  "cordova": {
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": {
      "cordova-plugin-file": {},
      "cordova-plugin-dialogs": {},
      "cordova-plugin-geolocation": {
        "GEOLOCATION_USAGE_DESCRIPTION": "pour localiser vos signalements",
        "GPS_REQUIRED": "true"
      },
      "cordova-plugin-network-information": {},
      "cordova-plugin-bluetooth-geolocation": {},
      "cordova-plugin-insomnia": {},
      "cordova-plugin-camera": {
        "CAMERA_USAGE_DESCRIPTION": "pour illustrez vos contributions",
        "PHOTOLIBRARY_USAGE_DESCRIPTION": "pour illustrez vos contributions",
        "ANDROIDX_CORE_VERSION": "1.6.+"
      },
      "cordova-plugin-inappbrowser": {}
    }
