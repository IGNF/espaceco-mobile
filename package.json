{
  "name": "guichet-mobile",
  "version": "2.3.0",
  "description": "Espace collaboratif mobile",
  "main": "index.html",
  "directories": {},
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node ./scripts/setproject.js && parcel ./src/index.html --out-dir ./.dist",
    "backup": "node ./scripts/backup.js",
    "lint": "eslint --fix src/ || exit 0",
    "build-dev": "node ./scripts/setproject.js && parcel build ./src/index.html --no-minify --no-source-maps --no-content-hash --public-url . --out-dir ./www index.html",
    "build": "node ./scripts/setproject.js && parcel build ./src/index.html --no-source-maps --no-content-hash --public-url . --out-dir ./www index.html"
  },
  "repository": {},
  "keywords": [],
  "author": "sai-mobile@ign.fr",
  "license": "IGN",
  "bugs": {
    "url": "http://sd-redmine.ign.fr/projects/guichet_mobile"
  },
  "homepage": "http://gitlab.dockerforge.ign.fr/express/guichet-mobile",
  "dependencies": {
    "bootbox": "^6.0.0",
    "cordova": "^11.0.0",
    "cordova-plugin-bluetooth-serial": "^0.4.7",
    "cordova-plugin-dialogs": "^2.0.2",
    "cordova-plugin-file": "^6.0.1",
    "cordova-plugin-geolocation": "^4.0.2",
    "cordova-plugin-listpicker": "^2.2.2",
    "cordova-plugin-network-information": "^2.0.2",
    "cordovapp": "git+http://gitlab.dockerforge.ign.fr/express/cordovapp.git#collab-form",
    "dotenv": "^16.0.3",
    "jquery": "^3.4.1",
    "mongo-parse": "^2.1.0",
    "ol": "^5.3.3",
    "ol-ext": "^3.2.13",
    "papaparse": "^5.3.0",
    "proj4": "^2.5.0",
    "webfontloader": "^1.6.28"
  },
  "devDependencies": {
    "clean-css": "^3.4.19",
    "cordova-android": "^10.1.2",
    "cordova-ios": "^6.2.0",
    "cordova-plugin-bluetooth-geolocation": "github:viglino/cordova-plugin-bluetooth-geolocation",
    "cordova-plugin-camera": "^6.0.0",
    "cordova-plugin-inappbrowser": "^5.0.0",
    "cordova-plugin-insomnia": "github:EddyVerbruggen/Insomnia-PhoneGap-Plugin",
    "eslint": "^6.5.1",
    "gulp": "^3.9.1",
    "gulp-jsdoc3": "^1.0.1",
    "parcel-bundler": "^1.12.5",
    "parcel-plugin-clean-dist": "0.0.6",
